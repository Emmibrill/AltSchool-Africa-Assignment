generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ENUMS
 */

enum UserRole {
  CREATOR
  EVENTEE
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

/**
 * USER
 */

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(EVENTEE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events        Event[]
  tickets       Ticket[]
  payments      Payment[]
  reminders     Reminder[]
  notifications Notification[]
}

/**
 * EVENT
 */

model Event {
  id          String  @id @default(uuid())
  title       String
  description String
  location    String
  imageUrl    String?
  price       Float
  capacity    Int
  soldCount   Int     @default(0)

  status EventStatus @default(DRAFT)

  startDate DateTime
  endDate   DateTime

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  tickets  Ticket[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([creatorId])
}

/**
 * TICKET
 */

model Ticket {
  id       String       @id @default(uuid())
  ticketNo String       @unique
  status   TicketStatus @default(ACTIVE)

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  qrCode QRCode?

  createdAt   DateTime     @default(now())
  attendances Attendance[]

  @@index([eventId])
  @@index([userId])
}

/**
 * PAYMENT
 */

model Payment {
  id        String        @id @default(uuid())
  reference String        @unique
  amount    Float
  status    PaymentStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  tickets Ticket[]

  createdAt DateTime @default(now())
}

/**
 * QR CODE
 */

model QRCode {
  id       String @id @default(uuid())
  code     String @unique
  imageUrl String

  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * ATTENDANCE
 */

model Attendance {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  eventId String
  userId  String

  checkedInAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
}

/**
 * REMINDER
 */

model Reminder {
  id      String   @id @default(uuid())
  message String
  sendAt  DateTime
  sent    Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * NOTIFICATION
 */

model Notification {
  id      String  @id @default(uuid())
  title   String
  message String
  read    Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * AUDIT LOG
 */

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  metadata String?

  userId    String?
  createdAt DateTime @default(now())

  @@index([userId])
}
